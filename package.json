{
  "name": "@interactions-hq/skyline",
  "version": "0.1.0",
  "description": "Skyline unified messaging SDK — one project, one credential pair, every platform. Cloud-brokered or dedicated transport.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/interactions-hq/skyline.git"
  },
  "homepage": "https://docs.interactions.co.in",
  "bugs": {
    "url": "https://github.com/interactions-hq/skyline/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./providers/imessage": {
      "types": "./dist/providers/imessage.d.ts",
      "import": "./dist/providers/imessage.js"
    },
    "./providers/terminal": {
      "types": "./dist/providers/terminal.d.ts",
      "import": "./dist/providers/terminal.js"
    },
    "./app": {
      "types": "./dist/miniapp/index.d.ts",
      "import": "./dist/miniapp/index.js"
    },
    "./miniapp": {
      "types": "./dist/miniapp/index.d.ts",
      "import": "./dist/miniapp/index.js"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "check": "bun run src/skyline.check.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "example:terminal": "bun run examples/terminal-agent.ts",
    "example:cloud": "bun run examples/cloud-agent.ts",
    "registry": "bun run scripts/registry-publish.ts"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0",
    "@grpc/proto-loader": "^0.7.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "imessage",
    "messaging",
    "sdk",
    "skyline",
    "interactions",
    "agents"
  ]
}
